<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="7"
    tools:context=".MainActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="0.5"
        android:gravity="bottom"
        android:background="@drawable/header_background"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textSize="30sp"
                android:layout_weight="1" />


            <ImageView
                android:id="@+id/iconInicio"
                android:layout_width="34dp"
                android:layout_height="40dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/border"
                android:contentDescription="@string/inicio"
                android:scaleType="fitCenter"
                android:src="@drawable/inicio"
                app:tint="@android:color/white" />

            <ImageView
                android:id="@+id/iconCerrarSesion"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:background="@drawable/border"
                android:contentDescription="@string/cerrarsion"
                android:scaleType="fitCenter"
                android:src="@drawable/cerrarsesion"
                app:tint="@android:color/white" />
        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tus Turnos Médicos"
            android:textColor="@android:color/white"
            android:textSize="25sp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:orientation="vertical">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp"
                android:background="@color/modern_icon_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="98dp"
                        android:layout_height="121dp"
                        android:src="@drawable/historial"
                        app:tint="@color/modern_blue" />

                    <TextView
                        android:layout_width="96dp"
                        android:layout_height="wrap_content"
                        android:text="Historial"
                        android:textAlignment="center"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp"
                android:background="@color/modern_icon_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="109dp"
                        android:layout_height="112dp"
                        android:src="@drawable/calendario"
                        app:tint="@color/modern_blue" />

                    <TextView
                        android:layout_width="107dp"
                        android:layout_height="wrap_content"
                        android:text="Nuevo Turno"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp"
                android:background="@color/modern_icon_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="99dp"
                        android:layout_height="99dp"
                        android:src="@drawable/phone"
                        app:tint="@color/modern_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teléfonos Útiles"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp"
                android:background="@color/modern_icon_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="99dp"
                        android:layout_height="99dp"
                        android:src="@drawable/map"
                        app:tint="@color/modern_blue" />

                    <TextView
                        android:layout_width="103dp"
                        android:layout_height="wrap_content"
                        android:text="Cómo Llegar"
                        android:textStyle="bold"
                        android:textAlignment="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
